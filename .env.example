# Учётные данные Omnicomm Online REST API (ТЗ §4.6)
# НЕ коммитить реальные значения. Этот файл — только пример.

# Боевой kz-контур. Точный адрес подтверждается отделом техобслуживания Omnicomm.
OMNICOMM_BASE_URL=https://kz.omnicomm.online

# Логин / пароль учётной записи с правами REST API.
LOGIN=
PASSWORD=

# Имя сервиса/контура (для доступа к отчётам обычно требуется, напр. omnicomm).
SERVICE=

# Цена топлива ₸/л — дефолт для денежной оценки (можно менять флагом --fuel-price
# и в карточке клиента платформы). По умолчанию 320.
FUEL_PRICE_KZT=320

# --- Авто-рассылка по расписанию (флаг --email) ----------------------------
# SMTP-сервер для отправки готовых отчётов. Без этих переменных --email no-op.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_TLS=1

# --- Шифрование кредов клиентов (P0-безопасность) --------------------------
# Пароли Omnicomm-клиентов в data/clients/*.json шифруются Fernet этим ключом.
# Сгенерировать: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Без ключа креды деградируют в base64 (только для dev). НЕ коммитить значение.
APP_CRYPTO_KEY=
# Альтернатива: парольная фраза, из которой ключ выводится PBKDF2 (если нет APP_CRYPTO_KEY).
APP_SECRET=

# --- Демо-контур (для отладки без боевых данных) ---------------------------
# Включается флагом --demo в CLI; адрес именно по HTTP (подтверждено документацией).
#   base: http://online.omnicomm.ru
#   login: rudemoru
#   password: rudemo123456

# --- AI-полировка рекомендаций через Claude (ai_engine.py, опционально) -----
# Без ключа движок отдаёт детерминированный текст рекомендаций (всё работает).
# С ключом Claude переформулирует посчитанные факты в деловой текст.
ANTHROPIC_API_KEY=
